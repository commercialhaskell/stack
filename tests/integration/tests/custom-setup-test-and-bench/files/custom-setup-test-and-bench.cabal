cabal-version: 3.4
name:          custom-setup-test-and-bench
version:       0.1.0.0
build-type:    Custom

custom-setup
  setup-depends: base >=4.14,
                 Cabal >=3.4

library
  exposed-modules:  Lib
  build-depends:    base >=4.14
  hs-source-dirs:   src
  default-language: Haskell2010

test-suite custom-setup-test-and-bench-tests
  type:             exitcode-stdio-1.0
  main-is:          Spec.hs
  build-depends:    base >=4.14,
                    custom-setup-test-and-bench
  hs-source-dirs:   test
  default-language: Haskell2010

benchmark custom-setup-test-and-bench-bench
  type:             exitcode-stdio-1.0
  main-is:          Bench.hs
  build-depends:    base >=4.14,
                    custom-setup-test-and-bench
  hs-source-dirs:   bench
  default-language: Haskell2010

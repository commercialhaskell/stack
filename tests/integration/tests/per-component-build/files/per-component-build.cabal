cabal-version: 2.0
name:          per-component-build
version:       0.1.0.0
build-type:    Simple
license:       BSD3

library
  exposed-modules: Lib
  hs-source-dirs:  src
  build-depends:   base
  default-language: Haskell2010

executable app1
  main-is:       Main.hs
  hs-source-dirs: app1
  build-depends:  base, per-component-build
  default-language: Haskell2010

executable app2
  main-is:       Main.hs
  hs-source-dirs: app2
  build-depends:  base, per-component-build
  default-language: Haskell2010

test-suite tests
  type:          exitcode-stdio-1.0
  main-is:       Main.hs
  hs-source-dirs: test
  build-depends:  base, per-component-build
  default-language: Haskell2010

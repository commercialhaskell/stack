cabal-version: 2.0
name:          consumer-pkg
version:       0.1.0.0
build-type:    Simple

library
  exposed-modules: Consumer
  build-depends:
    base >= 4.7 && < 5,
    str-sig,
    logger-sig,
    impl-pkg
  mixins:
    str-sig requires (Str as Str),
    logger-sig requires (Logger as Logger)
  hs-source-dirs:  src
  default-language: Haskell2010

executable consumer-demo
  main-is:         Main.hs
  build-depends:
    base >= 4.7 && < 5,
    consumer-pkg
  hs-source-dirs:  app
  default-language: Haskell2010
